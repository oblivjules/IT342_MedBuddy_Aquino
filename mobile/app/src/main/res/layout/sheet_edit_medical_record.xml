<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_2">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medical Record"
            android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5"
            android:textAppearance="@style/TextAppearance.MedBuddy.Body"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvAppointmentDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.MedBuddy.Caption"
            android:textColor="@color/text_secondary" />

        <!-- Diagnosis -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:text="Diagnosis *"
            android:textAppearance="@style/TextAppearance.MedBuddy.Label" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MedBuddy.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDiagnosis"
                style="@style/Widget.MedBuddy.InputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter diagnosis"
                android:inputType="textMultiLine"
                android:minLines="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Prescription section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:text="Prescription (optional)"
            android:textAppearance="@style/TextAppearance.MedBuddy.H3" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MedBuddy.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMedicine"
                style="@style/Widget.MedBuddy.InputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Medicine name"
                android:inputType="textCapSentences" />

        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDosage"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dosage"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_1"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRoute"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Route"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFrequency"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Frequency"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_1"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDuration"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Duration"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MedBuddy.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrescriptionNotes"
                style="@style/Widget.MedBuddy.InputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Prescription notes"
                android:inputType="textMultiLine"
                android:minLines="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Attached Files -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:text="Attached Files"
            android:textAppearance="@style/TextAppearance.MedBuddy.H3" />

        <TextView
            android:id="@+id/tvFilesStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5"
            android:text="Loading…"
            android:textAppearance="@style/TextAppearance.MedBuddy.Caption"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:id="@+id/llFiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:textAppearance="@style/TextAppearance.MedBuddy.Caption"
            android:textColor="@color/error"
            android:visibility="gone" />

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MedBuddy.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.MedBuddy.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="@dimen/space_1"
                android:layout_weight="1"
                android:text="Save Record" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
