<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="@dimen/space_2">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:textAppearance="@style/TextAppearance.MedBuddy.H1" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/space_1_5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2">

                    <FrameLayout
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tvAvatar"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:gravity="center"
                            android:text="DR"
                            android:textColor="@android:color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:gravity="center"
                        android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/space_1"
                        android:background="@drawable/bg_status_badge"
                        android:paddingHorizontal="@dimen/space_1_5"
                        android:paddingVertical="@dimen/space_0_5"
                        android:text="Doctor"
                        android:textAppearance="@style/TextAppearance.MedBuddy.Caption"
                        android:textColor="@color/primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1_5"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="Email"
                            android:src="@android:drawable/ic_dialog_email" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textAppearance="@style/TextAppearance.MedBuddy.Body" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="Phone"
                            android:src="@android:drawable/ic_menu_call" />

                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textAppearance="@style/TextAppearance.MedBuddy.Body" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSpecialization"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:textAppearance="@style/TextAppearance.MedBuddy.Body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPatientFeedback"
                        style="@style/Widget.MedBuddy.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="@dimen/space_1_5"
                        android:text="Patient Feedback" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditProfile"
                        style="@style/Widget.MedBuddy.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:text="Edit Profile" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1_5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2">

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.MedBuddy.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Log Out" />

</LinearLayout>
