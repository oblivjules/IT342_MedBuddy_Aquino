<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_2">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Complete Appointment"
            android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

        <TextView
            android:id="@+id/tvCompletionPatientName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5"
            android:textAppearance="@style/TextAppearance.MedBuddy.Body"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvPatientNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5"
            android:textAppearance="@style/TextAppearance.MedBuddy.Body"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <!-- Diagnosis -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:text="Diagnosis *"
            android:textAppearance="@style/TextAppearance.MedBuddy.BodyBold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MedBuddy.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDiagnosis"
                style="@style/Widget.MedBuddy.InputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter diagnosis"
                android:inputType="textMultiLine"
                android:minLines="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Prescription section header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:text="Prescription (optional)"
            android:textAppearance="@style/TextAppearance.MedBuddy.H3" />

        <!-- Medicine name -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MedBuddy.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMedicine"
                style="@style/Widget.MedBuddy.InputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Medicine name"
                android:inputType="textCapSentences" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dosage + Route row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDosage"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dosage"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_1"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRoute"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Route"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Frequency + Duration row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFrequency"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Frequency"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MedBuddy.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_1"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDuration"
                    style="@style/Widget.MedBuddy.InputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Duration"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Prescription notes -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MedBuddy.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrescriptionNotes"
                style="@style/Widget.MedBuddy.InputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Prescription notes"
                android:inputType="textMultiLine"
                android:minLines="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bill amount -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:text="Total Bill *"
            android:textAppearance="@style/TextAppearance.MedBuddy.BodyBold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MedBuddy.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_0_5"
            app:prefixText="₱">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBillAmount"
                style="@style/Widget.MedBuddy.InputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0.00"
                android:inputType="numberDecimal" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error message -->
        <TextView
            android:id="@+id/tvCompletionError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:textAppearance="@style/TextAppearance.MedBuddy.Caption"
            android:textColor="@color/error"
            android:visibility="gone" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelCompletion"
                style="@style/Widget.MedBuddy.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteAppointment"
                style="@style/Widget.MedBuddy.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="@dimen/space_1"
                android:layout_weight="1"
                android:text="Complete" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
