<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/space_2"
    android:background="@color/background">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/content_desc_medbuddy_logo"
        android:maxHeight="80dp"
        android:src="@drawable/medbuddy_logo_removebg_preview" />

    <!-- Welcome section with rounded background card -->
    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.MedBuddy.Card.Surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_2"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/primary"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_2">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome, Patient! 👋"
                android:textAppearance="@style/TextAppearance.MedBuddy.H1"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How are you feeling today?"
                android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                android:textColor="#CCffffff" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/space_1_5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Upcoming Appointment Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_1_5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2">

                    <!-- Header row: title + booked chip -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Upcoming Appointment"
                            android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

                        <!-- Styled "Booked" chip with colored background -->
                        <TextView
                            android:id="@+id/tvStatusChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_booked"
                            android:paddingHorizontal="@dimen/space_1"
                            android:paddingVertical="@dimen/space_0_5"
                            android:text="● Booked"
                            android:textAppearance="@style/TextAppearance.MedBuddy.Caption"
                            android:textColor="@color/chip_booked_text"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Doctor info row: avatar icon + name/spec -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Doctor avatar circle with icon -->
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_circle">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_profile"
                                android:contentDescription="Doctor icon"
                                app:tint="@android:color/white" />

                        </FrameLayout>

                        <!-- Doctor name and specialty -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/space_1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDoctorName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Dr. Michael Chen"
                                android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

                            <TextView
                                android:id="@+id/tvDoctorSpec"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Cardiologist"
                                android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvUpcomingCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="March 5, 2026 • 10:30 AM"
                        android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/space_1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1_5"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFindDoctor"
                            style="@style/Widget.MedBuddy.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="Book Doctor" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewDetails"
                            style="@style/Widget.MedBuddy.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/space_1"
                            android:text="View Details" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- About Your Medication Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="About Your Medication"
                        android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

                    <TextView
                        android:id="@+id/tvMedication"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:text="Lisinopril 10mg"
                        android:textAppearance="@style/TextAppearance.MedBuddy.Body" />

                    <TextView
                        android:id="@+id/tvMedicationDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_0_5"
                        android:text="Used to treat high blood pressure. Common side effects may include dizziness and dry cough."
                        android:textAppearance="@style/TextAppearance.MedBuddy.Caption" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="Quick Actions"
                android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.MedBuddy.Card.Surface"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_2">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:gravity="center"
                            android:text="+"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBookAppointment"
                            style="@style/Widget.MedBuddy.Button.Secondary"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="@dimen/space_1"
                            android:text="Book Appointment" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.MedBuddy.Card.Surface"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_1"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_2">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:gravity="center"
                            android:text="R"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMyAppointments"
                            style="@style/Widget.MedBuddy.Button.Secondary"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="@dimen/space_1"
                            android:text="My Records" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>