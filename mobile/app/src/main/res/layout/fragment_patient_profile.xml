<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="@dimen/space_2">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:textAppearance="@style/TextAppearance.MedBuddy.H1" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/space_1_5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2">

                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_avatar_circle"
                        android:gravity="center"
                        android:text="SJ"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1"
                        android:gravity="center"
                        android:textAppearance="@style/TextAppearance.MedBuddy.H2" />

                    <TextView
                        android:id="@+id/tvRoleChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/space_1"
                        android:background="@drawable/bg_status_badge"
                        android:paddingHorizontal="@dimen/space_1_5"
                        android:paddingVertical="@dimen/space_0_5"
                        android:text="Patient"
                        android:textAppearance="@style/TextAppearance.MedBuddy.Caption"
                        android:textColor="@color/primary" />

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.MedBuddy.Card.Surface"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1_5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_2">

                            <TextView
                                android:id="@+id/tvEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.MedBuddy.Body" />

                            <TextView
                                android:id="@+id/tvPatientId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_1"
                                android:textAppearance="@style/TextAppearance.MedBuddy.Body" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditProfile"
                        style="@style/Widget.MedBuddy.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="@dimen/space_1_5"
                        android:text="Edit Profile" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1_5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2">



                    <TextView
                        android:id="@+id/tvPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1_5"
                        android:text="Privacy &amp; Security"
                        android:textAppearance="@style/TextAppearance.MedBuddy.Body" />

                    <TextView
                        android:id="@+id/tvSupport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_1_5"
                        android:text="Help &amp; Support"
                        android:textAppearance="@style/TextAppearance.MedBuddy.Body" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.MedBuddy.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Log Out" />

</LinearLayout>
