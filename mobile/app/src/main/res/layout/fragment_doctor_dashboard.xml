<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/space_2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="@dimen/space_2"
        android:paddingTop="@dimen/space_2"
        android:paddingRight="@dimen/space_2">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_3"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:gravity="center"
            android:textColor="@color/error"
            android:textAppearance="@style/TextAppearance.MedBuddy.Body"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            style="@style/Widget.MedBuddy.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="@dimen/space_1"
            android:text="Retry"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome, Doctor! 👋"
                    android:textAppearance="@style/TextAppearance.MedBuddy.H1"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_0_5"
                    android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_1">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_0_5"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/colorPink"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_2">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Appointments"
                                android:textColor="@color/white"
                                android:textAppearance="@style/TextAppearance.MedBuddy.Caption" />

                            <TextView
                                android:id="@+id/tvAppointmentsCount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_1"
                                android:text="0"
                                android:textColor="@color/white"
                                android:textAppearance="@style/TextAppearance.MedBuddy.H1"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_0_5"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/status_completed_bg"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_2">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:contentDescription="Completed icon"
                                    android:src="@drawable/ic_calendar"
                                    android:tint="@color/status_completed_text" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_0_5"
                                    android:text="Completed"
                                    android:textColor="@color/status_completed_text"
                                    android:textAppearance="@style/TextAppearance.MedBuddy.Caption" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvCompletedCount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_1"
                                android:text="0"
                                android:textColor="@color/status_completed_text"
                                android:textAppearance="@style/TextAppearance.MedBuddy.H1"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MedBuddy.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Upcoming Today"
                        android:textAppearance="@style/TextAppearance.MedBuddy.H2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/nextPatientEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:gravity="center"
                        android:text="No upcoming appointments today."
                        android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                        android:textColor="@color/text_secondary"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/nextPatientContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNextPatientInitials"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="@color/colorPink"
                            android:gravity="center"
                            android:text="SJ"
                            android:textAppearance="@style/TextAppearance.MedBuddy.H2"
                            android:textColor="@color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNextPatientName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:textAppearance="@style/TextAppearance.MedBuddy.H2"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNextPatientTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_0_5"
                            android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvNextPatientReason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_0_5"
                            android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                            android:textColor="@color/text_secondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartConsultation"
                            style="@style/Widget.MedBuddy.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="Start Consultation" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="Quick Actions"
                android:textAppearance="@style/TextAppearance.MedBuddy.H2"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardViewSchedule"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_0_5"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/space_2">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="@color/pink_light">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="Schedule icon"
                                android:src="@drawable/ic_calendar_outline"
                                android:tint="@color/colorPink" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:gravity="center"
                            android:text="View Schedule"
                            android:textAppearance="@style/TextAppearance.MedBuddy.BodyBold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAddAvailability"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_0_5"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/space_2">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="@color/pink_light">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="Availability icon"
                                android:src="@drawable/ic_access_time"
                                android:tint="@color/colorPink" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:gravity="center"
                            android:text="Add Availability"
                            android:textAppearance="@style/TextAppearance.MedBuddy.BodyBold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="Upcoming Appointments"
                android:textAppearance="@style/TextAppearance.MedBuddy.H2"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:fillViewport="true"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupUpcomingFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="8dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAllUpcoming"
                        style="@style/Widget.MedBuddy.Chip.Filter"
                        android:text="All Upcoming"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipToday"
                        style="@style/Widget.MedBuddy.Chip.Filter"
                        android:text="Today" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipThisWeek"
                        style="@style/Widget.MedBuddy.Chip.Filter"
                        android:text="This Week" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvUpcomingEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:gravity="center"
                android:text="No appointments match this filter."
                android:textAppearance="@style/TextAppearance.MedBuddy.Body"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerUpcomingToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="@dimen/space_2" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>