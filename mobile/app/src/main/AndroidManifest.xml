<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet permission required for Retrofit API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MedBuddy"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Login is the entry point -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:label="@string/title_login"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:label="@string/title_register"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.PatientDashboardActivity"
            android:exported="false"
            android:label="@string/title_patient_dashboard" />

        <activity
            android:name=".ui.DoctorDashboardActivity"
            android:exported="false"
            android:label="@string/title_doctor_dashboard" />

        <activity
            android:name=".ui.FindDoctorActivity"
            android:exported="false"
            android:label="Find a Doctor"
            android:parentActivityName=".ui.PatientDashboardActivity" />

        <activity
            android:name=".ui.BookAppointmentActivity"
            android:exported="false"
            android:label="Book Appointment"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.FindDoctorActivity" />

        <activity
            android:name=".ui.MyAppointmentsActivity"
            android:exported="false"
            android:label="My Appointments" />


    </application>

</manifest>
