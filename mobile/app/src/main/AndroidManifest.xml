<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet permission required for Retrofit API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MedBuddy"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Login is the initial entry point, but MainActivity handles the actual flow -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login is the entry point for unauthenticated users -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:label="@string/title_login"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:label="@string/title_register"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.PatientDashboardActivity"
            android:exported="false"
            android:label="@string/title_patient_dashboard" />

        <activity
            android:name=".ui.DoctorDashboardActivity"
            android:exported="false"
            android:label="@string/title_doctor_dashboard" />

        <activity
            android:name=".ui.FindDoctorActivity"
            android:exported="false"
            android:label="Find a Doctor"
            android:parentActivityName=".ui.PatientDashboardActivity" />

        <activity
            android:name=".ui.BookAppointmentActivity"
            android:exported="false"
            android:label="Book Appointment"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.FindDoctorActivity" />

        <activity
            android:name=".ui.MyAppointmentsActivity"
            android:exported="false"
            android:label="My Appointments" />

        <activity
            android:name=".ui.MedicalHistoryActivity"
            android:exported="false"
            android:label="Medical History"
            android:parentActivityName=".ui.PatientDashboardActivity" />

        <activity
            android:name=".ui.MedicalRecordDetailActivity"
            android:exported="false"
            android:label="Medical Record Detail"
            android:parentActivityName=".ui.MedicalHistoryActivity" />

        <activity
            android:name=".ui.AppointmentDetailPatientActivity"
            android:exported="false"
            android:label="Appointment Details"
            android:parentActivityName=".ui.MyAppointmentsActivity" />

        <activity
            android:name=".ui.AppointmentDetailDoctorActivity"
            android:exported="false"
            android:label="Appointment Details"
            android:parentActivityName=".ui.MyAppointmentsActivity" />

        <activity
            android:name=".ui.CreateRecordActivity"
            android:exported="false"
            android:label="Create Medical Record"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.DoctorRatingsActivity"
            android:exported="false"
            android:label="My Ratings"
            android:parentActivityName=".ui.DoctorDashboardActivity" />

        <activity
            android:name=".ui.OAuthCallbackActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="medbuddy"
                    android:host="oauth-callback" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.PaymentResultActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="medbuddy"
                    android:host="payment"
                    android:pathPrefix="/" />
            </intent-filter>
        </activity>

    </application>

</manifest>
